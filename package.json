{
    "name": "terai-trail",
    "description": "The Terai Trail — a settlement survival game about post-Partition Sikh refugees in Pilibhit (1952). Built with Phaser 3 and TypeScript.",
    "version": "0.1.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yadavvi91/caulk-the-wagon.git"
    },
    "author": "yadavvi91",
    "license": "MIT",
    "scripts": {
        "dev": "node log.js dev & vite --config vite/config.dev.mjs",
        "build": "node log.js build & vite build --config vite/config.prod.mjs",
        "dev-nolog": "vite --config vite/config.dev.mjs",
        "build-nolog": "vite build --config vite/config.prod.mjs",
        "deploy": "npm run build-nolog && gh-pages -d dist",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "gh-pages": "^6.3.0",
        "typescript": "~5.7.2",
        "vite": "^6.3.1",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "phaser": "^3.90.0",
        "terser": "^5.39.0"
    }
}
